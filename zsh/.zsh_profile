export XDG_CONFIG_HOME=$HOME/.config

# ---------------------------------------------------------
# WSL-Specific Configurations
# ---------------------------------------------------------
if grep -qE "(Microsoft|WSL)" /proc/version &> /dev/null; then
    alias aws-vault="/mnt/c/awsvault/aws-vault.exe"

    export GALLIUM_DRIVER=d3d12
    export MESA_D3D12_DEFAULT_ADAPTER_NAME=NVIDIA

    addToPathFront /mnt/c/Windows/System32
    addToPathFront /mnt/c/awsvault
    addToPathFront /usr/lib/wsl/lib
else
    alias aws-vault="aws-vault"
fi

alias settings="env XDG_CURRENT_DESKTOP=GNOME gnome-control-center"
PERSONAL=$XDG_CONFIG_HOME/personal
source $PERSONAL/env
for i in `find -L $PERSONAL -type f ! -name "env"`; do
    source $i
done

source /usr/share/doc/fzf/examples/key-bindings.zsh
source /usr/share/doc/fzf/examples/completion.zsh

export REPOS=$HOME/git
export GOPATH=$HOME/go
export DOTFILES=$REPOS/.dotfiles
export GIT_EDITOR=nvim
export GPG_TTY=$(tty)

addToPathFront /usr/local/go/bin
addToPathFront $HOME/.local/scripts
addToPathFront $HOME/.local/bin
addToPathFront $HOME/.local/bin/dafny
addToPathFront $HOME/.local/go/bin
addToPathFront $HOME/go/bin
addToPathFront $HOME/adr-tools/src
addToPathFront ${ASDF_DATA_DIR:-$HOME/.asdf}/shims
